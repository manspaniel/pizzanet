{
  "name": "pizzanet-ar",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "wasm:build": "cd ../crates/ar-tracker-wasm && wasm-pack build --target web --release --out-dir ../../app/src/generated/ar-tracker-wasm --out-name ar_tracker_wasm",
    "predev": "pnpm wasm:build",
    "dev": "vite",
    "prebuild": "pnpm wasm:build",
    "build": "tsc -b && vite build",
    "lint": "oxlint",
    "recordings:analyze": "node scripts/analyze-recordings.mjs",
    "preview": "vite preview"
  },
  "dependencies": {
    "@hono/vite-dev-server": "^0.26.1",
    "@tailwindcss/vite": "^4.3.3",
    "hono": "^4.12.31",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwindcss": "^4.3.3",
    "three": "^0.185.1"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.185.1",
    "@types/webxr": "^0.5.24",
    "@vitejs/plugin-react": "^6.0.3",
    "oxlint": "^1.71.0",
    "typescript": "~6.0.2",
    "vite": "^8.1.1",
    "wasm-pack": "^0.15.0"
  }
}
